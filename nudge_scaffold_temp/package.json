{
  "name": "nudge_scaffold_temp",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F @nudge_scaffold_temp/backend dev",
    "dev:setup": "turbo -F @nudge_scaffold_temp/backend dev:setup"
  },
  "dependencies": {
    "@nudge_scaffold_temp/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nudge_scaffold_temp/config": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "^6"
  },
  "packageManager": "pnpm@10.17.1"
}
