# Convex env (loaded by convex dev / deploy). Do NOT commit secrets.

# Generated 32-byte secret, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=

# Convex deployment identifiers
CONVEX_DEPLOYMENT=dev:<your-deployment>
CONVEX_SITE_URL=https://<your-deployment>.convex.site
CONVEX_URL=https://<your-deployment>.convex.cloud

# Google OAuth client. Create a "Web application" OAuth client at
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (must match exactly):
#   ${CONVEX_SITE_URL}/api/auth/callback/google
# Authorized JavaScript origin:
#   ${CONVEX_SITE_URL}
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Deep-link scheme used by expo-linking for OAuth callbacks on native.
# Must be in auth.ts `trustedOrigins` (it is, by default).
NATIVE_APP_URL=nudge://

# Web app origin (used for email links, default callback base, etc.)
SITE_URL=http://localhost:8081
